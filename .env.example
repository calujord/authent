# ─────────────────────────────────────────────
#  Authent — Servicio de autenticación
#  Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────────

ENVIRONMENT=dev
DEBUG=False

# Base de datos
DB_NAME=authent_db
DB_USER=authent_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5453

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6393

# Web
WEB_PORT=8003

# Django
SECRET_KEY=generate-a-new-key-with-django-admin-generate-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Localización
LANGUAGE_CODE=es
TIME_ZONE=America/Mexico_City

# Media y Static
MEDIA_ROOT=/app/config/media
STATIC_ROOT=/app/config/staticfiles

# Email (Resend)
EMAIL_BACKEND=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=Authent <noreply@authent.app>

# AWS S3 (opcional, poner USE_S3=False para almacenamiento local)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=authent-media
AWS_S3_REGION_NAME=eu-north-1
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_FILE_OVERWRITE=False

# URL del servicio
SITE_URL=http://localhost:8020

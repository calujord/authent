# ─────────────────────────────────────────────────────────────────────────────
#  Authent — Configuración de producción
#  Dominio: https://authent.atharix.com
#
#  Este archivo contiene overrides NO-SECRETOS del entorno de producción.
#  Los valores secretos (SECRET_KEY, DB_PASSWORD, RESEND_API_KEY, etc.)
#  deben ir en el .env raíz (ignorado por git, inyectado en el servidor).
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ───────────────────────────────────────────────────────────────────
ENVIRONMENT=pro

# ── Dominio y hosts permitidos ────────────────────────────────────────────────
ALLOWED_HOSTS=authent.atharix.com,localhost,127.0.0.1

# ── CORS (solo el dominio de los clientes que consumen la API) ────────────────
# Añadir aquí cada frontend/app que haga peticiones a la API
CORS_ALLOWED_ORIGINS=https://authent.atharix.com

# ── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=https://authent.atharix.com

# ── Seguridad HTTPS ───────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── Email ─────────────────────────────────────────────────────────────────────
# Usar backend de Resend en producción.
# La API key se define en .env: RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_BACKEND=resend
DEFAULT_FROM_EMAIL=Atharix Auth <noreply@atharix.com>

# ── Base de datos ──────────────────────────────────────────────────────────────
# Ajustar según el servidor de producción.
# DB_PASSWORD se define en .env raíz.
DB_HOST=db
DB_PORT=5432
DB_NAME=authent_prod
DB_USER=authent_user
DB_CONN_MAX_AGE=600

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_EXTERNAL_PORT=6379

# ── Almacenamiento S3 ─────────────────────────────────────────────────────────
# Activar S3 en producción para servir media files.
# Las credenciales se definen en .env raíz.
USE_S3=True
AWS_S3_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID         → en .env raíz
# AWS_SECRET_ACCESS_KEY     → en .env raíz
# AWS_STORAGE_BUCKET_NAME   → en .env raíz

# ── Puerto expuesto por nginx ──────────────────────────────────────────────────
# HTTP y HTTPS se mapean fijo en docker-compose (80 y 443)
WEB_PORT=80

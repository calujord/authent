# ─────────────────────────────────────────────
#  Authent — Sobreescrituras para entorno dev
#  Cargado junto con .env cuando ENVIRONMENT=dev
# ─────────────────────────────────────────────

# En desarrollo se permite cualquier origen CORS
CORS_ALLOW_ALL_ORIGINS=True

# Mostrar contraseñas reset por consola en lugar de enviar email
# Cambiar a "resend" para probar el envío real de correos
EMAIL_BACKEND=console
